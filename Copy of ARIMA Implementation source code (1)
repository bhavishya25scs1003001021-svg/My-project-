{"cells":[{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from statsmodels.tsa.stattools import adfuller\n","from statsmodels.graphics.tsaplots import plot_acf, plot_pacf\n","from statsmodels.tsa.arima.model import ARIMA\n","from sklearn.metrics import mean_squared_error, mean_absolute_error\n","import warnings\n","\n","# Suppress warnings for cleaner output\n","warnings.filterwarnings(\"ignore\")\n","\n","def generate_synthetic_data():\n","    \"\"\"\n","    Generates a synthetic dataset resembling manufacturing product demand.\n","    Includes trend and seasonality.\n","    \"\"\"\n","    np.random.seed(42)\n","    # Date range: 5 years of monthly data\n","    dates = pd.date_range(start='2019-01-01', periods=60, freq='M')\n","\n","    # Base trend\n","    trend = np.linspace(100, 200, 60)\n","\n","    # Seasonality (12-month cycle)\n","    seasonality = 20 * np.sin(np.linspace(0, 3.14 * 10, 60))\n","\n","    # Noise (random fluctuations)\n","    noise = np.random.normal(loc=0, scale=10, size=60)\n","\n","    # Total Demand\n","    demand = trend + seasonality + noise\n","\n","    df = pd.DataFrame({'Date': dates, 'Demand': demand})\n","    df.set_index('Date', inplace=True)\n","    return df\n","\n","def check_stationarity(timeseries):\n","    \"\"\"\n","    Performs Augmented Dickey-Fuller test to check stationarity.\n","    \"\"\"\n","    print(\"Results of Dickey-Fuller Test:\")\n","    dftest = adfuller(timeseries, autolag='AIC')\n","    dfoutput = pd.Series(dftest[0:4], index=['Test Statistic','p-value','#Lags Used','Number of Observations Used'])\n","    for key,value in dftest[4].items():\n","        dfoutput['Critical Value (%s)'%key] = value\n","    print(dfoutput)\n","    return dfoutput['p-value']\n","\n","def run_arima_analysis():\n","    # 1. Load Data\n","    print(\"--- Loading Data ---\")\n","    data = generate_synthetic_data()\n","    print(data.head())\n","\n","    # 2. Visualize Original Series\n","    plt.figure(figsize=(12, 6))\n","    plt.plot(data['Demand'], label='Observed Demand')\n","    plt.title('Monthly Manufacturing Product Demand (2019-2023)')\n","    plt.xlabel('Date')\n","    plt.ylabel('Units Sold')\n","    plt.legend()\n","    plt.savefig('original_series.png') # Save for report\n","    plt.show()\n","\n","    # 3. Check Stationarity\n","    p_value = check_stationarity(data['Demand'])\n","\n","    # 4. Differencing (if non-stationary)\n","    # We assume first-order differencing is needed for this synthetic trend data\n","    data_diff = data['Demand'].diff().dropna()\n","\n","    plt.figure(figsize=(12, 6))\n","    plt.plot(data_diff, label='Differenced Demand', color='orange')\n","    plt.title('Differenced Time Series (1st Order)')\n","    plt.legend()\n","    plt.savefig('differenced_series.png')\n","    plt.show()\n","\n","    # Re-check stationarity on differenced data\n","    check_stationarity(data_diff)\n","\n","    # 5. ACF and PACF Plots to determine p and q\n","    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 8))\n","    plot_acf(data_diff, ax=ax1, lags=20)\n","    plot_pacf(data_diff, ax=ax2, lags=20)\n","    plt.tight_layout()\n","    plt.savefig('acf_pacf.png')\n","    plt.show()\n","\n","    # 6. Train-Test Split\n","    train_size = int(len(data) * 0.8)\n","    train, test = data['Demand'][0:train_size], data['Demand'][train_size:]\n","\n","    # 7. Fit ARIMA Model\n","    # Order (p,d,q) chosen based on theoretical visual inspection of synthetic data\n","    # p=1 (AR term), d=1 (Differencing), q=1 (MA term)\n","    print(\"\\n--- Fitting ARIMA(1,1,1) Model ---\")\n","    model = ARIMA(train, order=(1, 1, 1))\n","    model_fit = model.fit()\n","    print(model_fit.summary())\n","\n","    # 8. Forecasting\n","    forecast_result = model_fit.get_forecast(steps=len(test))\n","    forecast = forecast_result.predicted_mean\n","    conf_int = forecast_result.conf_int()\n","\n","    # 9. Evaluation\n","    mse = mean_squared_error(test, forecast)\n","    mae = mean_absolute_error(test, forecast)\n","    rmse = np.sqrt(mse)\n","    print(f'\\nMean Squared Error: {mse:.2f}')\n","    print(f'Root Mean Squared Error: {rmse:.2f}')\n","    print(f'Mean Absolute Error: {mae:.2f}')\n","\n","    # 10. Visualization of Forecast\n","    plt.figure(figsize=(14, 7))\n","    plt.plot(train.index, train, label='Training Data')\n","    plt.plot(test.index, test, label='Actual Demand', color='green')\n","    plt.plot(test.index, forecast, label='ARIMA Forecast', color='red', linestyle='--')\n","    plt.fill_between(test.index, conf_int.iloc[:, 0], conf_int.iloc[:, 1], color='pink', alpha=0.3, label='Confidence Interval')\n","    plt.title('ARIMA Model Forecast vs Actuals')\n","    plt.xlabel('Date')\n","    plt.ylabel('Demand')\n","    plt.legend()\n","    plt.savefig('forecast_results.png')\n","    plt.show()\n","\n","if __name__ == \"__main__\":\n","    run_arima_analysis()"],"outputs":[{"output_type":"stream","name":"stdout","text":["--- Loading Data ---\n","                Demand\n","Date                  \n","2019-01-31  104.967142\n","2019-02-28  110.460936\n","2019-03-31  127.356743\n","2019-04-30  140.308381\n","2019-05-31  121.404261\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Results of Dickey-Fuller Test:\n","Test Statistic                  1.044203\n","p-value                         0.994711\n","#Lags Used                     10.000000\n","Number of Observations Used    49.000000\n","Critical Value (1%)            -3.571472\n","Critical Value (5%)            -2.922629\n","Critical Value (10%)           -2.599336\n","dtype: float64\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Results of Dickey-Fuller Test:\n","Te